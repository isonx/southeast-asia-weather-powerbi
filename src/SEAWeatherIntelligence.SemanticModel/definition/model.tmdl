model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["DevMode"]

ref table Locations
ref table CurrentWeather
ref table DailyForecast
ref table AirQuality
ref table _Measures

